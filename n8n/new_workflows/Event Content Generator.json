      "parameters": {
        "promptType": "define",
        "text": "=Generate content for this event:\nTitle: {{ $json.event_title }}\nLocation: {{ $json.location }}\nDate: {{ $json.start }}\nAdditional context: {{ $json.prompt }}\n\nReturn only the JSON object.\n",
        "options": {
          "systemMessage": "You are a professional content creator for Swinburne Vietnam university.\nYour job is to generate engaging, bilingual marketing content for university events.\nALWAYS respond with a single valid JSON object only — no markdown, no prose, no code fences.\nRequired JSON keys:\n  social_post       — max 150 words, casual/energetic tone, English\n  email_newsletter  — max 300 words, formal tone, English\n  recruitment_ad    — max 100 words, persuasive/aspirational tone, English\n  vietnamese_version — Vietnamese translation of social_post\n"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
