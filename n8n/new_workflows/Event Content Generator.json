    {
      "parameters": {
        "jsCode": "// Handles both direct body and nested body.payload structures\nconst raw = $input.first().json;\nconst body = raw.body ?? raw;\nconst payload = body.payload ?? body;\n\nconst eventId = payload.event_id ?? body.event_id;\nif (!eventId) throw new Error('event_id is missing from Django payload');\n\nreturn [{\n  json: {\n    event_id: String(eventId),\n    event_title: payload.title ?? payload.event_title ?? 'Swinburne Vietnam Event',\n    prompt: payload.prompt ?? '',\n    start: payload.start ?? '',\n    end: payload.end ?? '',\n    location: payload.location ?? '',\n    timestamp: body.timestamp ?? new Date().toISOString(),\n  }\n}];\n"
      },
