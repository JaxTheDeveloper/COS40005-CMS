      ],
      "id": "2c814519-f991-4d24-910a-16b3430410e5",
      "name": "Content Generator"
    },
    {
      "parameters": {
        "jsCode": "// Parse the AI Agent's text output into structured JSON\nconst agentOutput = $input.first().json.output\n  ?? $input.first().json.text\n  ?? JSON.stringify($input.first().json);\n\nlet content = {};\ntry {\n  // Extract the first {...} block (handles cases where LLM adds preamble text)\n  const match = agentOutput.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    content = JSON.parse(match[0]);\n  } else {\n    // Fallback: wrap raw output in social_post\n    content = { social_post: agentOutput };\n  }\n} catch (e) {\n  content = { social_post: agentOutput, parse_error: e.message };\n}\n\n// Pull event_id from the upstream Extract node (not from AI Agent output)\nconst extracted = $('Extract Event Data').first().json;\n\nreturn [{\n  json: {\n    event_id: extracted.event_id,\n    event_title: extracted.event_title,\n    start: extracted.start,\n    end: extracted.end,\n    location: extracted.location,\n    generated_content: content,\n    generation_meta: {\n      generated_by: 'n8n-groq',\n      source: 'groq-llama3-3-70b',\n      generated_at: new Date().toISOString(),\n      model: 'llama-3.3-70b-versatile',\n    }\n  }\n}];\n"
      },
